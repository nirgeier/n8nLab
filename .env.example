# n8n Local Environment Configuration
# Copy this to .env and customize as needed

# Database Configuration
DB_USER=n8n
DB_PASSWORD=n8n_password
DB_NAME=n8n

# n8n Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Timezone
TZ=UTC

# Node Environment
NODE_ENV=development

# Optional: Advanced Configuration
# N8N_EDITOR_BASE_URL=http://localhost:5678
# N8N_WEBHOOK_TUNNEL_URL=http://localhost:5678
# WEBHOOK_TUNNEL_REDIRECT_URLS=http://localhost:5678
